# ============================================================
# Variaveis de ambiente do rag-codebase
# ============================================================
# Instrucoes:
#   1. Copie este arquivo para .env
#      cp .env.example .env
#   2. Preencha os valores abaixo conforme seu ambiente
#   3. NUNCA commite o arquivo .env no repositorio
# ============================================================

# ANTHROPIC_API_KEY - Chave de API da Anthropic (obrigatorio)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# CODEBASE_ROOT - caminho dos repositorios DENTRO do container/sistema (obrigatorio)
#
# Desenvolvimento local (WSL/Ubuntu, sem Docker):
#   Aponta diretamente para o diretorio dos clones no host
#   CODEBASE_ROOT=/opt/rag/codebase
#
# Producao (Docker):
#   O container monta o diretorio do host em /codebase (fixo)
#   Portanto CODEBASE_ROOT deve sempre ser /codebase no Docker
#   CODEBASE_ROOT=/codebase
# ============================================================
CODEBASE_ROOT=/opt/rag/codebase

# ============================================================
# CODEBASE_HOST_PATH - caminho dos repositorios NO Host (obrigatorio - apenas para Docker)
# Usado APENAS pelo docker-compose.yml para montar o volume
# Nao e lido pelo codigo da aplicacao (main.py)
#
# Desenvolvimento local (WSL/Ubuntu):
#   Nao e utilizado - o Docker nao e usado no desenvolvimento
#   Pode remover, comentar ou deixar com qualquer valor
#
# Producao (servidor Ubuntu):
#   Caminho absoluto no servidor (host) onde os clones estao salvos
#   CODEBASE_HOST_PATH=/data/codebase
# ============================================================
# CODEBASE_HOST_PATH=/opt/rag/codebase

# ============================================================
# APP_PORT - porta externa em que a aplicacao sera acessada no host (opcional - padrao 8000)
#
# Esta variavel controla APENAS a porta do lado de fora do container.
# Internamente, o container sempre roda na porta 8000 (fixo por design).
#
# Exemplos:
#   APP_PORT=8000  -> acessivel em http://localhost:8000  (padrao)
#   APP_PORT=9000  -> acessivel em http://localhost:9000
#
# O codigo da aplicacao e o Dockerfile NAO precisam ser alterados
# para mudar a porta de acesso - basta ajustar este valor.
# ============================================================
# APP_PORT=8000

# ============================================================
# DAEMON_STOP_ON_CONTEXT_SWITCH - para o daemon do cocoindex ao trocar de contexto (opcional)
#
# Desenvolvimento local (WSL/Ubuntu, GPU limitada):
#   Libera a VRAM imediatamente apos a troca de repo/branch.
#   O daemon sobe automaticamente na proxima busca.
#   DAEMON_STOP_ON_CONTEXT_SWITCH=true
#
# Producao (servidor com multiplos usuarios):
#   Nao deve ser ativado -- a troca de contexto de um usuario
#   interromperia as buscas dos demais.
#   Deixe ausente ou defina como false.
# ============================================================
# DAEMON_STOP_ON_CONTEXT_SWITCH=true
